@page
@model WebApp.Pages.Invoice.CreateModel
@{
    ViewData["Title"] = "Create New Invoice";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4">@ViewData["Title"]</h2>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Invoice Information</h5>

                        <div class="mb-3">
                            <label asp-for="InvoiceInput.CustomerID" class="form-label">Customer ID</label>
                            <input asp-for="InvoiceInput.CustomerID" class="form-control" type="number" min="1" step="1" required />
                            <span asp-validation-for="InvoiceInput.CustomerID" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="InvoiceInput.ProductID" class="form-label">Product ID</label>
                            <input asp-for="InvoiceInput.ProductID" class="form-control" type="number" min="1" step="1" required />
                            <span asp-validation-for="InvoiceInput.ProductID" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="InvoiceInput.TotalAmount" class="form-label">Total Amount ($)</label>
                            <input asp-for="InvoiceInput.TotalAmount" class="form-control" type="number" min="0.01" step="0.01"  required />
                            <span asp-validation-for="InvoiceInput.TotalAmount" class="text-danger"></span>
                        </div>

                        <hr class="my-4" />
                        <h5 class="card-title mb-3 text-muted">Optional Information</h5>

                        <div class="mb-3">
                            <label asp-for="InvoiceInput.TaxOfficeNumber" class="form-label">Tax Office Number</label>
                            <input asp-for="InvoiceInput.TaxOfficeNumber" class="form-control" placeholder="Optional" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="InvoiceInput.InvoicingParty" class="form-label">Invoicing Party</label>
                            <input asp-for="InvoiceInput.InvoicingParty" class="form-control" placeholder="Company Name" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="InvoiceInput.InvoicedParty" class="form-label">Invoiced Party</label>
                            <input asp-for="InvoiceInput.InvoicedParty" class="form-control" placeholder="Recipient Name" />
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary btn-lg px-5">Create Invoice</button>
                    <a asp-page="/Employee/Dashboard" class="btn btn-outline-secondary btn-lg">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}