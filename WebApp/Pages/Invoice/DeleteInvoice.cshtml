@page
@model WebApp.Pages.Invoice.DeleteInvoiceModel
@{
    ViewData["Title"] = "Delete Invoice";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-12">
            <h2 class="mb-4">@ViewData["Title"]</h2>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <strong>Success!</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Error!</strong> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">All Invoices</h5>
                </div>
                <div class="card-body">
                    @if (Model.AllInvoices.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Invoice ID</th>
                                        <th>Customer ID</th>
                                        <th>Product ID</th>
                                        <th>Total Amount</th>
                                        <th>Total with Tax</th>
                                        <th>Invoice Date</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var invoice in Model.AllInvoices)
                                    {
                                        <tr>
                                            <td>@invoice.InvoiceID</td>
                                            <td>@invoice.CustomerID</td>
                                            <td>@invoice.ProductID</td>
                                            <td>$@invoice.TotalAmount.ToString("N2")</td>
                                            <td>$@invoice.TotalWithTax.ToString("N2")</td>
                                            <td>@invoice.InvoiceDate.ToString("yyyy-MM-dd")</td>
                                            <td>
                                                <a asp-page="/Invoice/DeleteInvoice" asp-route-id="@invoice.InvoiceID" class="btn btn-sm btn-danger">
                                                    <i class="bi bi-trash"></i> Delete
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">No invoices found yet.</div>
                    }
                </div>
            </div>

            @if (Model.InvoiceToDelete != null)
            {
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">?? Delete Confirmation</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-warning">
                            <strong>Attention!</strong> This action cannot be undone. All related payments will also be deleted. Are you sure?
                        </div>

                        <dl class="row">
                            <dt class="col-sm-3">Invoice ID:</dt>
                            <dd class="col-sm-9">@Model.InvoiceToDelete.InvoiceID</dd>

                            <dt class="col-sm-3">Customer ID:</dt>
                            <dd class="col-sm-9">@Model.InvoiceToDelete.CustomerID</dd>

                            <dt class="col-sm-3">Product ID:</dt>
                            <dd class="col-sm-9">@Model.InvoiceToDelete.ProductID</dd>

                            <dt class="col-sm-3">Total Amount:</dt>
                            <dd class="col-sm-9">$@Model.InvoiceToDelete.TotalAmount.ToString("N2")</dd>

                            <dt class="col-sm-3">Total with Tax:</dt>
                            <dd class="col-sm-9">$@Model.InvoiceToDelete.TotalWithTax.ToString("N2")</dd>
                        </dl>

                        <form method="post">
                            <input type="hidden" name="invoiceId" value="@Model.InvoiceToDelete.InvoiceID" />
                            
                            <div class="mt-4">
                                <button type="submit" class="btn btn-danger btn-lg">
                                    <i class="bi bi-trash"></i> Yes, Delete Invoice
                                </button>
                                <a asp-page="/Invoice/DeleteInvoice" class="btn btn-secondary btn-lg">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <div class="mt-4">
                <a asp-page="/Employee/Dashboard" class="btn btn-secondary">Back to Home</a>
            </div>
        </div>
    </div>
</div>
