@page
@model WebApp.Pages.Invoice.DetailsModel
@{
    ViewData["Title"] = "Invoice Created Successfully";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="alert alert-success" role="alert">
                <h4 class="alert-heading">
                    <i class="bi bi-check-circle-fill me-2"></i>Success!
                </h4>
                <hr />
                <p class="mb-0">
                    Your invoice has been created successfully.
                </p>
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Invoice Details</h5>
                    <hr />
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Invoice ID:</strong>
                        </div>
                        <div class="col-md-8">
                            <span class="badge bg-primary fs-5">@Model.InvoiceId</span>
                        </div>
                    </div>
                    <hr />
                    <p class="text-muted mb-0">
                        <small>Please note or save your invoice number.</small>
                    </p>
                </div>
            </div>

            <div class="mt-4">
                <a asp-page="/Invoice/Create" class="btn btn-primary">Create New Invoice</a>
                <a asp-page="/Index" class="btn btn-secondary">Back to Home</a>
            </div>
        </div>
    </div>
</div>
