@page
@model IndexModel
@{
    ViewData["Title"] = "Employee Dashboard";
    string employeeName = "Admin User";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-5 p-3 bg-white shadow-sm rounded border">
        <div class="d-flex align-items-center">
            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white me-3" style="width: 50px; height: 50px;">
                <i class="bi bi-person-circle fs-3"></i>
            </div>
            <div>
                <h5 class="mb-0 text-muted small text-uppercase">Staff Terminal</h5>
                <h4 class="mb-0 fw-bold text-dark">Welcome, @employeeName</h4>
            </div>
        </div>
        <div>
            <button onclick="confirmExit()" class="btn btn-danger shadow-sm px-4 fw-bold">
                <i class="bi bi-box-arrow-right"></i> EXIT
            </button>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-3">
            <div class="card text-center shadow-sm h-100 border-0 border-top border-4 border-info">
                <div class="card-body">
                    <i class="bi bi-person-plus display-4 text-info"></i>
                    <h5 class="card-title mt-3 fw-bold">New Customer</h5>
                    <a asp-page="/Customer/Create" class="btn btn-outline-info w-100 mt-2">Add Customer</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm h-100 border-0 border-top border-4 border-info">
                <div class="card-body">
                    <i class="bi bi-bar-chart-line display-4 text-info"></i>
                    <h5 class="card-title mt-3 fw-bold">Customer Report</h5>
                    <a asp-page="/Reports/CustomerSummary" class="btn btn-outline-info w-100 mt-2">View Reports</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm h-100 border-0 border-top border-4 border-primary">
                <div class="card-body">
                    <i class="bi bi-plus-circle display-4 text-primary"></i>
                    <h5 class="card-title mt-3 fw-bold">New Invoice</h5>
                    <a asp-page="/Invoice/Create" class="btn btn-primary w-100 mt-2">Create Invoice</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm h-100 border-0 border-top border-4 border-primary">
                <div class="card-body">
                    <i class="bi bi-trash display-4 text-danger"></i>
                    <h5 class="card-title mt-3 fw-bold text-danger">Delete Invoice</h5>
                    <a asp-page="/Invoice/DeleteInvoice" class="btn btn-danger w-100 mt-2">Remove Record</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm h-100 border-0 border-top border-4 border-warning">
                <div class="card-body">
                    <i class="bi bi-arrow-repeat display-4 text-warning"></i>
                    <h5 class="card-title mt-3 fw-bold">Update Stock</h5>
                    <a asp-page="/Product/UpdateStock" class="btn btn-warning text-white w-100 mt-2">Update Inventory</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmExit() {
            if (confirm("You are about to exit the dashboard. Are you sure you want to return to the login screen?")) {
                window.location.href = "/Index";
            }
        }
    </script>
}