@page
@model WebApp.Pages.Customer.PersonalInfoModel
@{
    ViewData["Title"] = "Personal Information";
}

<div class="container-fluid min-vh-100 bg-light-gray py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-dark mb-0">
                    <i class="bi bi-person-lines-fill text-primary me-2"></i>Personal Details
                </h2>
                <a asp-page="/Customer/Dashboard" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-3">
                    <h5 class="card-title text-white mb-0 text-center">Account Profile Summary</h5>
                </div>
                <div class="card-body bg-white p-4">
                    <div class="row g-4">
                        <div class="col-12 border-bottom pb-3">
                            <label class="text-muted small text-uppercase fw-bold">Full Name</label>
                            <div class="fs-5 fw-semibold text-dark">
                                <i class="bi bi-person me-2 text-primary"></i>@Model.CurrentCustomer?.Name
                            </div>
                        </div>

                        <div class="col-md-6 border-bottom pb-3">
                            <label class="text-muted small text-uppercase fw-bold">Email Address</label>
                            <div class="text-dark">
                                <i class="bi bi-envelope me-2 text-primary"></i>@(Model.CurrentCustomer?.Email ?? "N/A")
                            </div>
                        </div>

                        <div class="col-md-6 border-bottom pb-3">
                            <label class="text-muted small text-uppercase fw-bold">Phone Number</label>
                            <div class="text-dark">
                                <i class="bi bi-telephone me-2 text-primary"></i>@(Model.CurrentCustomer?.Phone ?? "N/A")
                            </div>
                        </div>

                        <div class="col-12 border-bottom pb-3">
                            <label class="text-muted small text-uppercase fw-bold">Registered Address</label>
                            <div class="text-dark">
                                <i class="bi bi-geo-alt me-2 text-primary"></i>@(Model.CurrentCustomer?.Address ?? "No address registered.")
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="text-muted small text-uppercase fw-bold">Account Type</label>
                            <div>
                                <span class="badge @(Model.CurrentCustomer?.CustomerType == "Corporate" ? "bg-info" : "bg-success") px-3 py-2">
                                    <i class="bi bi-shield-check me-1"></i>@Model.CurrentCustomer?.CustomerType
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light py-3 text-center">
                    <small class="text-muted italic">
                        <i class="bi bi-info-circle me-1"></i>To update these details, please use the <strong>Info Management</strong> section.
                    </small>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .bg-light-gray {
        background-color: #f1f3f5;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    .card {
        transition: none;
    }
    /* Dashboard'daki hover etkisini burada istemiyoruz */
</style>