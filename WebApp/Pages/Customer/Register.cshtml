@page
@model WebApp.Pages.Customer.RegisterModel
@{
    Layout = null; // Giriş ekranı gibi bağımsız bir tasarım
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - DENE System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            padding: 20px;
        }

        .register-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0px 20px 50px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 550px;
            overflow: hidden;
        }

        .register-header {
            background: #1a2a6c;
            color: white;
            padding: 30px;
            text-align: center;
        }

        .register-body {
            padding: 40px;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px;
            border: 2px solid #e2e8f0;
        }

            .form-control:focus {
                border-color: #00a8e8;
                box-shadow: 0 0 0 4px rgba(0,168,232,0.1);
            }

        .btn-register {
            background: #1a2a6c;
            color: white;
            border-radius: 12px;
            padding: 12px;
            font-weight: 700;
            width: 100%;
            transition: 0.3s;
            border: none;
        }

            .btn-register:hover {
                background: #00a8e8;
                transform: translateY(-2px);
            }

        .text-danger {
            font-size: 0.85rem;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="register-card">
        <div class="register-header">
            <h2 class="mb-0">DENE Account</h2>
            <p class="opacity-75 mb-0">Create your customer account</p>
        </div>

        <div class="register-body">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold small">Full Name</label>
                    <input asp-for="Input.Name" class="form-control" placeholder="Jhon Done" />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small">Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="example@dene.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small">Phone</label>
                        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="05XXXXXXXXX" />
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small">Customer Type</label>
                    <select asp-for="Input.CustomerType" class="form-select form-control">
                        <option value="Individual">Individual (Bireysel)</option>
                        <option value="Corporate">Corporate (Kurumsal)</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small">Address</label>
                    <textarea asp-for="Input.Address" class="form-control" rows="2" placeholder="Street, City, Postal Code..."></textarea>
                    <span asp-validation-for="Input.Address" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-register mb-3 shadow-sm">REGISTER NOW</button>

                <div class="text-center">
                    <a asp-page="/Index" class="text-decoration-none text-muted small fw-bold">
                        <i class="bi bi-arrow-left"></i> Back to Login
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>