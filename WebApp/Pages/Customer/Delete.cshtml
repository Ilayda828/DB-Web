@page
@model WebApp.Pages.Customer.DeleteModel
@{
    ViewData["Title"] = "Delete Customer";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <h2 class="mb-4">@ViewData["Title"]</h2>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <strong>Success!</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Error!</strong> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Current Customers</h5>
                </div>
                <div class="card-body">
                    @if (Model.AllCustomers.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Customer ID</th>
                                        <th>Full Name</th>
                                        <th>Email</th>
                                        <th>Phone</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var customer in Model.AllCustomers)
                                    {
                                        <tr>
                                            <td>@customer.CustomerID</td>
                                            <td>@customer.Name</td>
                                            <td>@customer.Email</td>
                                            <td>@customer.Phone</td>
                                            <td>
                                                <a asp-page="/Customer/Delete" asp-route-id="@customer.CustomerID" class="btn btn-sm btn-danger">
                                                    <i class="bi bi-trash"></i> Delete
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">No customers found yet.</div>
                    }
                </div>
            </div>

            @if (Model.CustomerToDelete != null)
            {
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">?? Delete Confirmation</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-warning">
                            <strong>Attention!</strong> This action cannot be undone. Are you sure you want to delete the following customer?
                        </div>

                        <dl class="row">
                            <dt class="col-sm-3">Customer ID:</dt>
                            <dd class="col-sm-9">@Model.CustomerToDelete.CustomerID</dd>

                            <dt class="col-sm-3">Full Name:</dt>
                            <dd class="col-sm-9">@Model.CustomerToDelete.Name</dd>

                            <dt class="col-sm-3">Email:</dt>
                            <dd class="col-sm-9">@Model.CustomerToDelete.Email</dd>

                            <dt class="col-sm-3">Phone:</dt>
                            <dd class="col-sm-9">@Model.CustomerToDelete.Phone</dd>
                        </dl>

                        <form method="post">
                            <input type="hidden" name="customerId" value="@Model.CustomerToDelete.CustomerID" />
                            
                            <div class="mt-4">
                                <button type="submit" class="btn btn-danger btn-lg">
                                    <i class="bi bi-trash"></i> Yes, Delete
                                </button>
                                <a asp-page="/Customer/Delete" class="btn btn-secondary btn-lg">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <div class="mt-4">
                <a asp-page="/Employee/Dashboard" class="btn btn-secondary">Back to Home</a>
            </div>
        </div>
    </div>
</div>
