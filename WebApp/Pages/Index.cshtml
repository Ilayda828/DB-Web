@page
@model IndexModel
@{
    ViewData["Title"] = "Login Portal";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --primary-dark: #1a2a6c;
            --accent-blue: #00a8e8;
            --transition: all 0.3s ease;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            margin: 0;
        }

        .main-container {
            background: white;
            border-radius: 24px;
            box-shadow: 0px 20px 60px rgba(0,0,0,0.15);
            display: flex;
            width: 950px;
            min-height: 580px;
        }

        .left-panel {
            flex: 1.2;
            padding: 50px;
            display: flex;
            flex-direction: column;
            border-right: 1px solid #edf2f7;
        }

        .type-btn {
            flex: 1;
            padding: 30px;
            border: 2px solid #eaedf2;
            border-radius: 20px;
            background: white;
            transition: var(--transition);
            cursor: pointer;
            text-align: center;
        }

            .type-btn:hover {
                border-color: var(--accent-blue);
                transform: translateY(-5px);
            }

            .type-btn i {
                font-size: 2.5rem;
                color: var(--primary-dark);
                display: block;
                margin-bottom: 10px;
            }

        .form-control {
            border-radius: 12px;
            padding: 12px;
            border: 2px solid #e2e8f0;
        }

        .btn-login {
            background: var(--primary-dark);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            width: 100%;
            margin-top: 20px;
            transition: var(--transition);
            cursor: pointer;
        }

            .btn-login:hover {
                background: var(--accent-blue);
                transform: translateY(-2px);
            }

        .btn-back {
            background: #f8fafc;
            color: #64748b;
            border: 2px solid #e2e8f0;
            padding: 12px 20px;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-back:hover {
                transform: translateX(-5px);
            }

        .btn-switch {
            flex-grow: 1;
            background: #64748b;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
        }

        .right-panel {
            flex: 0.8;
            background: linear-gradient(to bottom right, var(--primary-dark), #b21f1f, #fdbb2d);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            flex-direction: column;
        }

        .brand-logo {
            font-size: 5rem;
            font-weight: 900;
            letter-spacing: 10px;
        }

        .register-link {
            border: 2px solid var(--primary-dark);
            border-radius: 14px;
            padding: 14px;
            text-align: center;
            font-weight: 700;
            color: var(--primary-dark);
            text-decoration: none;
            display: block;
        }
    </style>
</head>
<body>
    <div class="main-container">
        <div class="left-panel">
            <h2 class="fw-bold mb-1" id="form-title" style="color: var(--primary-dark);">Access Portal</h2>
            <p class="text-muted mb-4" id="form-subtitle">Select identity to continue</p>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger p-2 small">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                </div>
            }

            <div id="selection-stage">
                <div class="d-flex gap-3 mt-2">
                    <button class="type-btn" onclick="selectType('customer')">
                        <i class="bi bi-person-bounding-box"></i><span class="fw-bold">As Customer</span>
                    </button>
                    <button class="type-btn" onclick="selectType('employee')">
                        <i class="bi bi-person-workspace"></i><span class="fw-bold">As Employee</span>
                    </button>
                </div>
            </div>

            <div id="login-form-area" style="display: none;">
                <form method="post" asp-page-handler="Login">
                    <input type="hidden" name="userType" id="userTypeHidden" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold" id="nameLabel">User Name</label>
                        <input type="text" name="userName" class="form-control" id="nameInput" required autocomplete="off">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold" id="idLabel">Password / ID</label>
                        <input type="password" name="password" class="form-control" id="idInput" required autocomplete="new-password">
                    </div>

                    <button type="submit" class="btn-login">LOGIN</button>

                    <div class="d-flex gap-2 mt-3">
                        <button type="button" class="btn-back" onclick="resetSelection()"><i class="bi bi-chevron-left"></i> To Back</button>
                        <button type="button" class="btn-switch" onclick="switchUserType()">Change Login Type</button>
                    </div>
                </form>
            </div>

            <div class="register-container mt-auto pt-4">
                <a asp-page="/Customer/Register" class="register-link">Register New Customer</a>
            </div>
        </div>
        <div class="right-panel">
            <div class="brand-logo">DENE</div>
        </div>
    </div>

    <script>
        let currentMode = '';
        function selectType(type) {
            currentMode = type;
            document.getElementById('userTypeHidden').value = type;
            document.getElementById('selection-stage').style.display = 'none';
            document.getElementById('login-form-area').style.display = 'block';
            updateUI();
        }
        function resetSelection() {
            document.getElementById('selection-stage').style.display = 'block';
            document.getElementById('login-form-area').style.display = 'none';
            clearInputs();
        }
        function switchUserType() {
            currentMode = (currentMode === 'customer') ? 'employee' : 'customer';
            document.getElementById('userTypeHidden').value = currentMode;
            clearInputs();
            updateUI();
        }
        function clearInputs() {
            document.getElementById('nameInput').value = '';
            document.getElementById('idInput').value = '';
        }
        function updateUI() {
            const nameLabel = document.getElementById('nameLabel');
            const idLabel = document.getElementById('idLabel');
            const title = document.getElementById('form-title');
            if (currentMode === 'customer') {
                title.innerText = "Customer Login";
                nameLabel.innerText = "Customer Name";
                idLabel.innerText = "Customer ID";
            } else {
                title.innerText = "Staff Terminal";
                nameLabel.innerText = "Employee Name";
                idLabel.innerText = "Employee Password";
            }
        }
    </script>
</body>
</html>